# Firebase Realtime Database — enables cross-device sync (phone remote control)
# Leave blank to run in local-only mode (no sync)
#
# Setup steps:
# 1. Go to https://console.firebase.google.com
# 2. Create a new project (e.g. "quadient-stress")
# 3. Add a Realtime Database (Build → Realtime Database → Create database)
#    → Choose "Start in test mode" (allows all reads/writes for 30 days)
# 4. Go to Project Settings → General → Your apps → Add app (Web)
# 5. Copy the config values below
# 6. Add these as Environment Variables in your Vercel project settings
#    (Settings → Environment Variables)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
